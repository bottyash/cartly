# ══════════════════════════════════════════════════════════════════════════
# Cartly — Environment Configuration
# Copy this to .env and fill in the values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# 🤖 OpenRouter LLM (REQUIRED)
# Get your free API key at: https://openrouter.ai
# ─────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=Cartly

# ─────────────────────────────────────────────
# 🗄️ PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_DSN=postgresql://cartly:cartly_secret@postgres:5432/cartly
POSTGRES_DB=cartly
POSTGRES_USER=cartly
POSTGRES_PASSWORD=cartly_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─────────────────────────────────────────────
# 🔐 Admin Dashboard
# ─────────────────────────────────────────────
ADMIN_TOKEN=cartly-admin-2026

# ─────────────────────────────────────────────
# ⚙️ API Settings
# ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# ─────────────────────────────────────────────
# 📋 Observability
# ─────────────────────────────────────────────
LOG_DIR=/app/observability/logs

# ─────────────────────────────────────────────
# 💰 Refund Policy Thresholds
# ─────────────────────────────────────────────
THRESHOLD_AMOUNT=500
FAITHFULNESS_FLOOR=0.70

# ─────────────────────────────────────────────
# ☁️ AWS (Production only — leave blank for local)
# ─────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_EC2_HOST=
AWS_EC2_USER=ubuntu
EC2_SSH_KEY_PATH=~/.ssh/cartly-key.pem

# ─────────────────────────────────────────────
# 🌐 CORS / App URL
# Set to your EC2 public IP or domain in production
# ─────────────────────────────────────────────
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
